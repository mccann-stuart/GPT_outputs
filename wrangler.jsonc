{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "deliverables",
  "main": "src/worker.mjs",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
