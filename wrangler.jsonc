{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "deliverables",
  "main": "src/worker.mjs",
  "compatibility_date": "2025-09-27",
  "build": {
    "command": "npm run build:public"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "GITHUB_REPO": "mccann-stuart/GPT_outputs",
    "GITHUB_BRANCH": "main",
    "GITHUB_AUTHOR_NAME": "GPT Outputs Upload",
    "GITHUB_AUTHOR_EMAIL": "uploads@gpt-outputs.local"
  },
  "assets": {
    "directory": "public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
