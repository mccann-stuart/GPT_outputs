{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "deliverables",
  "main": "src/worker.mjs",
  "compatibility_date": "2025-09-27",
  "build": {
    "command": "npm run build:public"
  },
  "observability": {
    "enabled": true
  },
  "r2_buckets": [
    {
      "binding": "JSX_UPLOADS",
      "bucket_name": "jsxupload"
    }
  ],
  "assets": {
    "directory": "public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*", "/jsxupload/Files/*"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
